}, {
  "@id" : "_:genid2",
  "http://www.w3.org/ns/shacl#datatype" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
  } ],
  "http://www.w3.org/ns/shacl#maxCount" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#integer",
    "@value" : "1"
  } ],
  "http://www.w3.org/ns/shacl#message" : [ {
    "@value" : "An aggregation formula must be represented as a string."
  } ],
  "http://www.w3.org/ns/shacl#path" : [ {
    "@id" : "http://example.org/fair-assessment#formula"
  } ]
}, {
  "@id" : "_:genid20",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/ns/shacl#SPARQLConstraint"
  } ],
  "http://www.w3.org/ns/shacl#message" : [ {
    "@value" : "If testResult is Fail, the value must be exactly 0.0."
  } ],
  "http://www.w3.org/ns/shacl#select" : [ {
    "@value" : "\n            PREFIX fairAss: <http://example.org/fair-assessment#>\n\n            SELECT $this\n            WHERE {\n                $this fairAss:testResult fairAss:Fail ;\n                      fairAss:value ?value .\n                FILTER (?value != 0.0)\n            }\n        "
  } ]
}, {
  "@id" : "_:genid21",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/ns/shacl#SPARQLConstraint"
  } ],
  "http://www.w3.org/ns/shacl#message" : [ {
    "@value" : "If testResult is Indeterminate, the value must be greater than 0 and less than 1."
  } ],
  "http://www.w3.org/ns/shacl#select" : [ {
    "@value" : "\n            PREFIX fairAss: <http://example.org/fair-assessment#>\n\n            SELECT $this\n            WHERE {\n                $this fairAss:testResult fairAss:Indeterminate ;\n                      fairAss:value ?value .\n                FILTER (?value <= 0.0 || ?value >= 1.0)\n            }\n        "
  } ]
}, {
  "@id" : "_:genid22",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/ns/shacl#SPARQLConstraint"
  } ],
  "http://www.w3.org/ns/shacl#message" : [ {
    "@value" : "If testResult is Pass, the value must be exactly 1.0."
  } ],
  "http://www.w3.org/ns/shacl#select" : [ {
    "@value" : "\n            PREFIX fairAss: <http://example.org/fair-assessment#>\n\n            SELECT $this\n            WHERE {\n                $this fairAss:testResult fairAss:Pass ;\n                      fairAss:value ?value .\n                FILTER (?value != 1.0)\n            }\n        "
  } ]
}, {
  "@id" : "_:genid23",
  "http://www.w3.org/ns/shacl#datatype" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#decimal"
  } ],
  "http://www.w3.org/ns/shacl#maxCount" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#integer",
    "@value" : "1"
  } ],
  "http://www.w3.org/ns/shacl#message" : [ {
    "@value" : "A scoring function must have exactly one minimum value."
  } ],
  "http://www.w3.org/ns/shacl#minCount" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#integer",
    "@value" : "1"
  } ],
  "http://www.w3.org/ns/shacl#path" : [ {
    "@id" : "http://example.org/fair-assessment#minValue"
  } ]
}, {
  "@id" : "_:genid24",
  "http://www.w3.org/ns/shacl#datatype" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#decimal"
  } ],
  "http://www.w3.org/ns/shacl#maxCount" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#integer",
    "@value" : "1"
  } ],
  "http://www.w3.org/ns/shacl#message" : [ {
    "@value" : "A scoring function must have exactly one maximum value."
  } ],
  "http://www.w3.org/ns/shacl#minCount" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#integer",
    "@value" : "1"
  } ],
  "http://www.w3.org/ns/shacl#path" : [ {
    "@id" : "http://example.org/fair-assessment#maxValue"
  } ]
}, {
  "@id" : "_:genid25",
  "http://www.w3.org/ns/shacl#datatype" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
  } ],
  "http://www.w3.org/ns/shacl#maxCount" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#integer",
    "@value" : "1"
  } ],
  "http://www.w3.org/ns/shacl#message" : [ {
    "@value" : "A scoring function formula must be a string."
  } ],
  "http://www.w3.org/ns/shacl#path" : [ {
    "@id" : "http://example.org/fair-assessment#formula"
  } ]
}, {
  "@id" : "_:genid26",
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/ns/shacl#SPARQLConstraint"
  } ],
  "http://www.w3.org/ns/shacl#message" : [ {
    "@value" : "The minimum value of a scoring function must not be greater than its maximum value."
  } ],
  "http://www.w3.org/ns/shacl#select" : [ {
    "@value" : "\n            PREFIX fairAss: <http://example.org/fair-assessment#>\n\n            SELECT $this\n            WHERE {\n                $this fairAss:minValue ?min ;\n                      fairAss:maxValue ?max .\n                FILTER (?min > ?max)\n            }\n        "
  } ]
}, {

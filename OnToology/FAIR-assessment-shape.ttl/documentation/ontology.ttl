###  http://example.org/fair-assessment-shapes#FAIRSubPrincipleShape
<http://example.org/fair-assessment-shapes#FAIRSubPrincipleShape> rdf:type owl:NamedIndividual ,
                                                                           <http://www.w3.org/ns/shacl#NodeShape> ;
                                                                  <http://www.w3.org/ns/shacl#property> _:genid18 ;
                                                                  <http://www.w3.org/ns/shacl#targetClass> <https://w3id.org/fair/principles/terms/FAIR-SubPrinciple> .

_:genid18 <http://www.w3.org/ns/shacl#in> [ ] ;
<http://www.w3.org/ns/shacl#maxCount> 1 ;
<http://www.w3.org/ns/shacl#message> "A FAIR sub-principle may specify whether it applies to data, metadata, or both." ;
<http://www.w3.org/ns/shacl#path> <http://example.org/fair-assessment#appliesTo> .


###  http://example.org/fair-assessment-shapes#FailResultShape
<http://example.org/fair-assessment-shapes#FailResultShape> rdf:type owl:NamedIndividual ,
                                                                     <http://www.w3.org/ns/shacl#NodeShape> ;
                                                            <http://www.w3.org/ns/shacl#sparql> _:genid20 ;
                                                            <http://www.w3.org/ns/shacl#targetClass> <http://example.org/fair-assessment#SubPrincipleResult> .

_:genid20 rdf:type <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
           <http://www.w3.org/ns/shacl#message> "If testResult is Fail, the value must be exactly 0.0." ;
           <http://www.w3.org/ns/shacl#select> """
            PREFIX fairAss: <http://example.org/fair-assessment#>

            SELECT $this
            WHERE {
                $this fairAss:testResult fairAss:Fail ;
                      fairAss:value ?value .
                FILTER (?value != 0.0)
            }
        """ .


###  http://example.org/fair-assessment-shapes#IndeterminateResultShape
<http://example.org/fair-assessment-shapes#IndeterminateResultShape> rdf:type owl:NamedIndividual ,
                                                                              <http://www.w3.org/ns/shacl#NodeShape> ;
                                                                     <http://www.w3.org/ns/shacl#sparql> _:genid21 ;
                                                                     <http://www.w3.org/ns/shacl#targetClass> <http://example.org/fair-assessment#SubPrincipleResult> .

_:genid21 rdf:type <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
           <http://www.w3.org/ns/shacl#message> "If testResult is Indeterminate, the value must be greater than 0 and less than 1." ;
           <http://www.w3.org/ns/shacl#select> """
            PREFIX fairAss: <http://example.org/fair-assessment#>

            SELECT $this
            WHERE {
                $this fairAss:testResult fairAss:Indeterminate ;
                      fairAss:value ?value .
                FILTER (?value <= 0.0 || ?value >= 1.0)
            }
        """ .


###  http://example.org/fair-assessment-shapes#PassResultShape
<http://example.org/fair-assessment-shapes#PassResultShape> rdf:type owl:NamedIndividual ,
                                                                     <http://www.w3.org/ns/shacl#NodeShape> ;
                                                            <http://www.w3.org/ns/shacl#sparql> _:genid22 ;
                                                            <http://www.w3.org/ns/shacl#targetClass> <http://example.org/fair-assessment#SubPrincipleResult> .

_:genid22 rdf:type <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
           <http://www.w3.org/ns/shacl#message> "If testResult is Pass, the value must be exactly 1.0." ;
           <http://www.w3.org/ns/shacl#select> """
            PREFIX fairAss: <http://example.org/fair-assessment#>

            SELECT $this
            WHERE {
                $this fairAss:testResult fairAss:Pass ;
                      fairAss:value ?value .
                FILTER (?value != 1.0)
            }
        """ .


###  http://example.org/fair-assessment-shapes#ScoringFunctionShape
<http://example.org/fair-assessment-shapes#ScoringFunctionShape> rdf:type owl:NamedIndividual ,
                                                                          <http://www.w3.org/ns/shacl#NodeShape> ;
                                                                 <http://www.w3.org/ns/shacl#property> _:genid23 ,
                                                                                                       _:genid24 ,
                                                                                                       _:genid25 ;
                                                                 <http://www.w3.org/ns/shacl#sparql> _:genid26 ;
                                                                 <http://www.w3.org/ns/shacl#targetClass> <http://example.org/fair-assessment#ScoringFunction> .

_:genid23 <http://www.w3.org/ns/shacl#datatype> xsd:decimal ;
           <http://www.w3.org/ns/shacl#maxCount> 1 ;
           <http://www.w3.org/ns/shacl#message> "A scoring function must have exactly one minimum value." ;
           <http://www.w3.org/ns/shacl#minCount> 1 ;
           <http://www.w3.org/ns/shacl#path> <http://example.org/fair-assessment#minValue> .

_:genid24 <http://www.w3.org/ns/shacl#datatype> xsd:decimal ;
           <http://www.w3.org/ns/shacl#maxCount> 1 ;
           <http://www.w3.org/ns/shacl#message> "A scoring function must have exactly one maximum value." ;
           <http://www.w3.org/ns/shacl#minCount> 1 ;
           <http://www.w3.org/ns/shacl#path> <http://example.org/fair-assessment#maxValue> .

_:genid25 <http://www.w3.org/ns/shacl#datatype> xsd:string ;
           <http://www.w3.org/ns/shacl#maxCount> 1 ;
           <http://www.w3.org/ns/shacl#message> "A scoring function formula must be a string." ;
           <http://www.w3.org/ns/shacl#path> <http://example.org/fair-assessment#formula> .

_:genid26 rdf:type <http://www.w3.org/ns/shacl#SPARQLConstraint> ;
           <http://www.w3.org/ns/shacl#message> "The minimum value of a scoring function must not be greater than its maximum value." ;
           <http://www.w3.org/ns/shacl#select> """
            PREFIX fairAss: <http://example.org/fair-assessment#>

            SELECT $this
            WHERE {
                $this fairAss:minValue ?min ;
                      fairAss:maxValue ?max .
                FILTER (?min > ?max)
            }
        """ .



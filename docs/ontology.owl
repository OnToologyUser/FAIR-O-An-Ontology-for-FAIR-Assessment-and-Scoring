    <!-- http://www.w3.org/ns/prov#Activity -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Activity"/>
    


    <!-- http://www.w3.org/ns/prov#Entity -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Entity"/>
    


    <!-- http://www.w3.org/ns/prov#Plan -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Plan"/>
    


    <!-- http://www.w3.org/ns/prov#SoftwareAgent -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#SoftwareAgent"/>
    


    <!-- https://w3id.org/fair-o#AggregationMethod -->


    <owl:Class rdf:about="https://w3id.org/fair-o#AggregationMethod">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Plan"/>
        <rdfs:comment xml:lang="en">A method for combining individual sub-principle scores into principle-level or overall scores.</rdfs:comment>
        <rdfs:label xml:lang="en">Aggregation Method</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/fair-o#AssessmentScope -->


    <owl:Class rdf:about="https://w3id.org/fair-o#AssessmentScope">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/fair-o#DataAndMetadata"/>
                    <rdf:Description rdf:about="https://w3id.org/fair-o#DataScope"/>
                    <rdf:Description rdf:about="https://w3id.org/fair-o#MetadataScope"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">The scope of what is being assessed: data, metadata, or both.</rdfs:comment>
        <rdfs:label xml:lang="en">Assessment Scope</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/fair-o#CalculationAlgorithm -->


    <owl:Class rdf:about="https://w3id.org/fair-o#CalculationAlgorithm">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Plan"/>
        <rdfs:comment xml:lang="en">The computational procedure or method used to evaluate a sub-principle and produce a score.</rdfs:comment>
        <rdfs:label xml:lang="en">Scoring Algorithm</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/fair-o#FAIRAssessment -->


    <owl:Class rdf:about="https://w3id.org/fair-o#FAIRAssessment">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment xml:lang="en">A quality assessment of a digital object against FAIR principles at a specific point in time.</rdfs:comment>
        <rdfs:label xml:lang="en">FAIR Assessment</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/fair-o#ScoringFunction -->


    <owl:Class rdf:about="https://w3id.org/fair-o#ScoringFunction">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">A mathematical or logical function that maps assessment evidence to a numeric score for a sub-principle.</rdfs:comment>
        <rdfs:label xml:lang="en">Scoring Function</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/fair-o#SubPrincipleResult -->


    <owl:Class rdf:about="https://w3id.org/fair-o#SubPrincipleResult">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment xml:lang="en">The assessment result for a specific FAIR sub-principle (e.g., F1, A1.1, I2).</rdfs:comment>
        <rdfs:label xml:lang="en">Sub-Principle Result</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/fair-o#TestOutcome -->


    <owl:Class rdf:about="https://w3id.org/fair-o#TestOutcome">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/fair-o#Fail"/>
                    <rdf:Description rdf:about="https://w3id.org/fair-o#Indeterminate"/>
                    <rdf:Description rdf:about="https://w3id.org/fair-o#Pass"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">The result of a FAIR test (e.g., Pass, Fail, or Indeterminate).</rdfs:comment>
        <rdfs:label xml:lang="en">Test Outcome</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/fair/principles/terms/FAIR-SubPrinciple -->


    <owl:Class rdf:about="https://w3id.org/fair/principles/terms/FAIR-SubPrinciple"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/fair-o#DataAndMetadata -->


    <owl:NamedIndividual rdf:about="https://w3id.org/fair-o#DataAndMetadata">
        <rdf:type rdf:resource="https://w3id.org/fair-o#AssessmentScope"/>
        <rdfs:label xml:lang="en">Data and Metadata</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/fair-o#DataScope -->


    <owl:NamedIndividual rdf:about="https://w3id.org/fair-o#DataScope">
        <rdf:type rdf:resource="https://w3id.org/fair-o#AssessmentScope"/>
        <rdfs:label xml:lang="en">Data</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/fair-o#Fail -->


    <owl:NamedIndividual rdf:about="https://w3id.org/fair-o#Fail">
        <rdf:type rdf:resource="https://w3id.org/fair-o#TestOutcome"/>
        <skos:notation>FAIL</skos:notation>
        <rdfs:comment xml:lang="en">The test was not satisfied (score = 0).</rdfs:comment>
        <rdfs:label xml:lang="en">Fail</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/fair-o#Indeterminate -->


    <owl:NamedIndividual rdf:about="https://w3id.org/fair-o#Indeterminate">
        <rdf:type rdf:resource="https://w3id.org/fair-o#TestOutcome"/>
        <skos:notation>INDETERMINATE</skos:notation>
        <rdfs:comment xml:lang="en">The test was partially satisfied (0 &lt; score &lt; 1).</rdfs:comment>
        <rdfs:label xml:lang="en">Indeterminate</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/fair-o#MetadataScope -->


    <owl:NamedIndividual rdf:about="https://w3id.org/fair-o#MetadataScope">
        <rdf:type rdf:resource="https://w3id.org/fair-o#AssessmentScope"/>
        <rdfs:label xml:lang="en">Metadata</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://w3id.org/fair-o#Pass -->


    <owl:NamedIndividual rdf:about="https://w3id.org/fair-o#Pass">
        <rdf:type rdf:resource="https://w3id.org/fair-o#TestOutcome"/>
        <skos:notation>PASS</skos:notation>
        <rdfs:comment xml:lang="en">The test was fully satisfied (score = 1).</rdfs:comment>
        <rdfs:label xml:lang="en">Pass</rdfs:label>
    </owl:NamedIndividual>
</rdf:RDF>




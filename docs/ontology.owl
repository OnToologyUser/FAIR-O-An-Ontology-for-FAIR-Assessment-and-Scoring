    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/fair-o#appliesScoringFunction -->


    <owl:ObjectProperty rdf:about="https://w3id.org/fair-o#appliesScoringFunction">
        <rdfs:domain rdf:resource="https://w3id.org/fair-o#CalculationAlgorithm"/>
        <rdfs:range rdf:resource="https://w3id.org/fair-o#ScoringFunction"/>
        <rdfs:comment xml:lang="en">Links an algorithm to the scoring function it uses.</rdfs:comment>
        <rdfs:label xml:lang="en">applies scoring function</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/fair-o#appliesTo -->


    <owl:ObjectProperty rdf:about="https://w3id.org/fair-o#appliesTo">
        <rdfs:domain rdf:resource="https://w3id.org/fair/principles/terms/FAIR-SubPrinciple"/>
        <rdfs:range rdf:resource="https://w3id.org/fair-o#AssessmentScope"/>
        <rdfs:comment xml:lang="en">Indicates whether a sub-principle applies to data, metadata, or both.</rdfs:comment>
        <rdfs:label xml:lang="en">applies to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/fair-o#assessmentScope -->


    <owl:ObjectProperty rdf:about="https://w3id.org/fair-o#assessmentScope">
        <rdfs:domain rdf:resource="https://w3id.org/fair-o#SubPrincipleResult"/>
        <rdfs:range rdf:resource="https://w3id.org/fair-o#AssessmentScope"/>
        <rdfs:comment xml:lang="en">Indicates whether the sub-principle result pertains to data, metadata, or both.</rdfs:comment>
        <rdfs:label xml:lang="en">assessment scope</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/fair-o#computedUsing -->


    <owl:ObjectProperty rdf:about="https://w3id.org/fair-o#computedUsing">
        <rdfs:domain rdf:resource="https://w3id.org/fair-o#SubPrincipleResult"/>
        <rdfs:range rdf:resource="https://w3id.org/fair-o#CalculationAlgorithm"/>
        <rdfs:comment xml:lang="en">Links a sub-principle result to the algorithm used to compute it.</rdfs:comment>
        <rdfs:label xml:lang="en">computed using</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/fair-o#forSubPrinciple -->


    <owl:ObjectProperty rdf:about="https://w3id.org/fair-o#forSubPrinciple">
        <rdfs:domain rdf:resource="https://w3id.org/fair-o#SubPrincipleResult"/>
        <rdfs:range rdf:resource="https://w3id.org/fair/principles/terms/FAIR-SubPrinciple"/>
        <rdfs:comment xml:lang="en">Links a sub-principle result to the specific FAIR sub-principle it evaluates (defined in the official FAIR Vocabulary).</rdfs:comment>
        <rdfs:label xml:lang="en">for sub-principle</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/fair-o#hasSubPrincipleResult -->


    <owl:ObjectProperty rdf:about="https://w3id.org/fair-o#hasSubPrincipleResult">
        <rdfs:domain rdf:resource="https://w3id.org/fair-o#FAIRAssessment"/>
        <rdfs:range rdf:resource="https://w3id.org/fair-o#SubPrincipleResult"/>
        <rdfs:comment xml:lang="en">Links an assessment to individual sub-principle results.</rdfs:comment>
        <rdfs:label xml:lang="en">has sub-principle result</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/fair-o#implementedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/fair-o#implementedBy">
        <rdfs:domain rdf:resource="https://w3id.org/fair-o#CalculationAlgorithm"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/prov#SoftwareAgent"/>
        <rdfs:comment xml:lang="en">Links the algorithm to the software that implements it.</rdfs:comment>
        <rdfs:label xml:lang="en">implemented by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/fair-o#testResult -->


    <owl:ObjectProperty rdf:about="https://w3id.org/fair-o#testResult">
        <rdfs:domain rdf:resource="https://w3id.org/fair-o#SubPrincipleResult"/>
        <rdfs:range rdf:resource="https://w3id.org/fair-o#TestOutcome"/>
        <rdfs:comment xml:lang="en">The outcome of the test for the sub-principle.</rdfs:comment>
        <rdfs:label xml:lang="en">test result</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/fair-o#usesAggregationMethod -->


    <owl:ObjectProperty rdf:about="https://w3id.org/fair-o#usesAggregationMethod">
        <rdfs:domain rdf:resource="https://w3id.org/fair-o#FAIRAssessment"/>
        <rdfs:range rdf:resource="https://w3id.org/fair-o#AggregationMethod"/>
        <rdfs:comment xml:lang="en">Links an assessment to the method used to aggregate sub-principle scores.</rdfs:comment>
        <rdfs:label xml:lang="en">uses aggregation method</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/fair-o#wasAssessedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/fair-o#wasAssessedBy">
        <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:range rdf:resource="https://w3id.org/fair-o#FAIRAssessment"/>
        <rdfs:comment xml:lang="en">Links a resource to a FAIR assessment that evaluated it.</rdfs:comment>
        <rdfs:label xml:lang="en">was assessed by</rdfs:label>
    </owl:ObjectProperty>
    



PREFIX fairo: <https://w3id.org/fair-o#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT ?assessment ?result ?subPrinciple ?scope ?scopeLabel
WHERE {
  ?assessment a fairo:FAIRAssessment ;
              fairo:hasSubPrincipleResult ?result .

  ?result a fairo:SubPrincipleResult ;
          fairo:forSubPrinciple ?subPrinciple ;
          fairo:assessmentScope ?scope .

  OPTIONAL {
    ?scope rdfs:label ?scopeLabel .
  }
}
ORDER BY ?assessment ?subPrinciple ?scope
@prefix : <http://example.org/fair-assessment-shapes#> .
@prefix fairAss: <http://example.org/fair-assessment#> .
@prefix fairVocab: <https://w3id.org/fair/principles/terms/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .


@prefix : <http://example.org/fair-assessment-shapes#> .
@prefix fairAss: <http://example.org/fair-assessment#> .
@prefix fairVocab: <https://w3id.org/fair/principles/terms/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .

################################################################################
# FAIR Assessment Shape

:FAIRAssessmentShape
    a sh:NodeShape ;
    sh:targetClass fairAss:FAIRAssessment ;

    sh:property [
        sh:path fairAss:fairScore ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 4.0 ;
        sh:message "A FAIR assessment must have exactly one overall FAIR score between 0 and 4." ;
    ] ;

    sh:property [
        sh:path fairAss:fScore ;
        sh:datatype xsd:decimal ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "The Findable score must be a decimal between 0 and 1." ;
    ] ;

    sh:property [
        sh:path fairAss:aScore ;
        sh:datatype xsd:decimal ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "The Accessible score must be a decimal between 0 and 1." ;
    ] ;

    sh:property [
        sh:path fairAss:iScore ;
        sh:datatype xsd:decimal ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "The Interoperable score must be a decimal between 0 and 1." ;
    ] ;

    sh:property [
        sh:path fairAss:rScore ;
        sh:datatype xsd:decimal ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "The Reusable score must be a decimal between 0 and 1." ;
    ] ;

    sh:property [
        sh:path fairAss:hasSubPrincipleResult ;
        sh:class fairAss:SubPrincipleResult ;
        sh:minCount 1 ;
        sh:message "A FAIR assessment must have at least one sub-principle result." ;
    ] ;

    sh:property [
        sh:path fairAss:usesAggregationMethod ;
        sh:class fairAss:AggregationMethod ;
        sh:maxCount 1 ;
        sh:message "If present, the aggregation method must be an instance of fairAss:AggregationMethod." ;
    ] ;

    sh:property [
        sh:path prov:startedAtTime ;
        sh:datatype xsd:dateTime ;
        sh:maxCount 1 ;
        sh:message "Assessment start time must be a valid xsd:dateTime." ;
    ] ;

    sh:property [
        sh:path prov:endedAtTime ;
        sh:datatype xsd:dateTime ;
        sh:maxCount 1 ;
        sh:message "Assessment end time must be a valid xsd:dateTime." ;
    ] .

# Assessed Resource Shape

:AssessedResourceShape
    a sh:NodeShape ;
    sh:targetSubjectsOf fairAss:wasAssessedBy ;

    sh:property [
        sh:path fairAss:wasAssessedBy ;
        sh:class fairAss:FAIRAssessment ;
        sh:minCount 1 ;
        sh:message "A resource assessed by fairAss:wasAssessedBy must point to a FAIR assessment." ;
    ] .

# Sub-Principle Result Shape

:SubPrincipleResultShape
    a sh:NodeShape ;
    sh:targetClass fairAss:SubPrincipleResult ;

    sh:property [
        sh:path fairAss:forSubPrinciple ;
        sh:class fairVocab:FAIR-SubPrinciple ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A sub-principle result must refer to exactly one FAIR sub-principle." ;
    ] ;

    sh:property [
        sh:path fairAss:testResult ;
        sh:in (
            fairAss:Pass
            fairAss:Fail
            fairAss:Indeterminate
        ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A sub-principle result must have exactly one test outcome: Pass, Fail, or Indeterminate." ;
    ] ;

    sh:property [
        sh:path fairAss:assessmentScope ;
        sh:in (
            fairAss:DataScope
            fairAss:MetadataScope
            fairAss:DataAndMetadata
        ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A sub-principle result must specify exactly one assessment scope." ;
    ] ;

    sh:property [
        sh:path fairAss:value ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "A sub-principle result must have exactly one decimal value between 0 and 1." ;
    ] ;

    sh:property [
        sh:path fairAss:evidence ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "A sub-principle result should include textual evidence." ;
    ] ;

    sh:property [
        sh:path fairAss:computedUsing ;
        sh:class fairAss:CalculationAlgorithm ;
        sh:maxCount 1 ;
        sh:message "If present, computedUsing must point to a CalculationAlgorithm." ;
    ] .


# Outcome / Score Consistency Rules

:PassResultShape
    a sh:NodeShape ;
    sh:targetClass fairAss:SubPrincipleResult ;

    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "If testResult is Pass, the value must be exactly 1.0." ;
        sh:select """
            PREFIX fairAss: <http://example.org/fair-assessment#>

            SELECT $this
            WHERE {
                $this fairAss:testResult fairAss:Pass ;
                      fairAss:value ?value .
                FILTER (?value != 1.0)
            }
        """ ;
    ] .

:FailResultShape
    a sh:NodeShape ;
    sh:targetClass fairAss:SubPrincipleResult ;

    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "If testResult is Fail, the value must be exactly 0.0." ;
        sh:select """
            PREFIX fairAss: <http://example.org/fair-assessment#>

            SELECT $this
            WHERE {
                $this fairAss:testResult fairAss:Fail ;
                      fairAss:value ?value .
                FILTER (?value != 0.0)
            }
        """ ;
    ] .

:IndeterminateResultShape
    a sh:NodeShape ;
    sh:targetClass fairAss:SubPrincipleResult ;

    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "If testResult is Indeterminate, the value must be greater than 0 and less than 1." ;
        sh:select """
            PREFIX fairAss: <http://example.org/fair-assessment#>

            SELECT $this
            WHERE {
                $this fairAss:testResult fairAss:Indeterminate ;
                      fairAss:value ?value .
                FILTER (?value <= 0.0 || ?value >= 1.0)
            }
        """ ;
    ] .


# Assessment Scope Shape

:AssessmentScopeShape
    a sh:NodeShape ;
    sh:targetClass fairAss:AssessmentScope ;

    sh:in (
        fairAss:DataScope
        fairAss:MetadataScope
        fairAss:DataAndMetadata
    ) ;

    sh:message "Assessment scope must be one of DataScope, MetadataScope, or DataAndMetadata." .


# Test Outcome Shape

:TestOutcomeShape
    a sh:NodeShape ;
    sh:targetClass fairAss:TestOutcome ;

    sh:in (
        fairAss:Pass
        fairAss:Fail
        fairAss:Indeterminate
    ) ;

    sh:message "Test outcome must be one of Pass, Fail, or Indeterminate." .


# FAIR Sub-Principle Shape

:FAIRSubPrincipleShape
    a sh:NodeShape ;
    sh:targetClass fairVocab:FAIR-SubPrinciple ;

    sh:property [
        sh:path fairAss:appliesTo ;
        sh:in (
            fairAss:DataScope
            fairAss:MetadataScope
            fairAss:DataAndMetadata
        ) ;
        sh:maxCount 1 ;
        sh:message "A FAIR sub-principle may specify whether it applies to data, metadata, or both." ;
    ] .

# Scoring Function Shape

:ScoringFunctionShape
    a sh:NodeShape ;
    sh:targetClass fairAss:ScoringFunction ;

    sh:property [
        sh:path fairAss:minValue ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A scoring function must have exactly one minimum value." ;
    ] ;

    sh:property [
        sh:path fairAss:maxValue ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A scoring function must have exactly one maximum value." ;
    ] ;

    sh:property [
        sh:path fairAss:formula ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:message "A scoring function formula must be a string." ;
    ] ;

    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "The minimum value of a scoring function must not be greater than its maximum value." ;
        sh:select """
            PREFIX fairAss: <http://example.org/fair-assessment#>

            SELECT $this
            WHERE {
                $this fairAss:minValue ?min ;
                      fairAss:maxValue ?max .
                FILTER (?min > ?max)
            }
        """ ;
    ] .

# Calculation Algorithm Shape

:CalculationAlgorithmShape
    a sh:NodeShape ;
    sh:targetClass fairAss:CalculationAlgorithm ;

    sh:property [
        sh:path fairAss:algorithmDescription ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "A calculation algorithm should have a human-readable description." ;
    ] ;

    sh:property [
        sh:path fairAss:sourceCode ;
        sh:datatype xsd:anyURI ;
        sh:maxCount 1 ;
        sh:message "Source code must be provided as a URI." ;
    ] ;

    sh:property [
        sh:path fairAss:appliesScoringFunction ;
        sh:class fairAss:ScoringFunction ;
        sh:maxCount 1 ;
        sh:message "If present, appliesScoringFunction must point to a ScoringFunction." ;
    ] ;

    sh:property [
        sh:path fairAss:implementedBy ;
        sh:class prov:SoftwareAgent ;
        sh:maxCount 1 ;
        sh:message "If present, implementedBy must point to a prov:SoftwareAgent." ;
    ] .

# Aggregation Method Shape

:AggregationMethodShape
    a sh:NodeShape ;
    sh:targetClass fairAss:AggregationMethod ;

    sh:property [
        sh:path fairAss:formula ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:message "An aggregation formula must be represented as a string." ;
    ] .

# Every SubPrincipleResult should be attached to at least one FAIRAssessment

:SubPrincipleResultAttachedToAssessmentShape
    a sh:NodeShape ;
    sh:targetClass fairAss:SubPrincipleResult ;

    sh:property [
        sh:path [ sh:inversePath fairAss:hasSubPrincipleResult ] ;
        sh:class fairAss:FAIRAssessment ;
        sh:minCount 1 ;
        sh:message "Every sub-principle result should be linked from at least one FAIR assessment." ;
    ] .
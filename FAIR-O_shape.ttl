@prefix : <http://w3id.org/fair-o-shapes#> .
@prefix fairo: <https://w3id.org/fair-o#> .
@prefix fairVocab: <https://w3id.org/fair/principles/terms/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct: <http://purl.org/dc/terms/> .

################################################################################
# FAIR Assessment Shape

:FAIRAssessmentShape
    a sh:NodeShape ;
    sh:targetClass fairo:FAIRAssessment ;

    sh:property [
        sh:path fairo:fairScore ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 4.0 ;
        sh:message "A FAIR assessment must have exactly one overall FAIR score between 0 and 4." ;
    ] ;

    sh:property [
        sh:path fairo:fScore ;
        sh:datatype xsd:decimal ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "The Findable score must be a decimal between 0 and 1." ;
    ] ;

    sh:property [
        sh:path fairo:aScore ;
        sh:datatype xsd:decimal ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "The Accessible score must be a decimal between 0 and 1." ;
    ] ;

    sh:property [
        sh:path fairo:iScore ;
        sh:datatype xsd:decimal ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "The Interoperable score must be a decimal between 0 and 1." ;
    ] ;

    sh:property [
        sh:path fairo:rScore ;
        sh:datatype xsd:decimal ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "The Reusable score must be a decimal between 0 and 1." ;
    ] ;

    sh:property [
        sh:path fairo:hasSubPrincipleResult ;
        sh:class fairo:SubPrincipleResult ;
        sh:minCount 1 ;
        sh:message "A FAIR assessment must have at least one sub-principle result." ;
    ] ;

    sh:property [
        sh:path fairo:usesAggregationMethod ;
        sh:class fairo:AggregationMethod ;
        sh:maxCount 1 ;
        sh:message "If present, the aggregation method must be an instance of fairo:AggregationMethod." ;
    ] ;

    sh:property [
        sh:path prov:startedAtTime ;
        sh:datatype xsd:dateTime ;
        sh:maxCount 1 ;
        sh:message "Assessment start time must be a valid xsd:dateTime." ;
    ] ;

    sh:property [
        sh:path prov:endedAtTime ;
        sh:datatype xsd:dateTime ;
        sh:maxCount 1 ;
        sh:message "Assessment end time must be a valid xsd:dateTime." ;
    ] .

# Assessed Resource Shape

:AssessedResourceShape
    a sh:NodeShape ;
    sh:targetSubjectsOf fairo:wasAssessedBy ;

    sh:property [
        sh:path fairo:wasAssessedBy ;
        sh:class fairo:FAIRAssessment ;
        sh:minCount 1 ;
        sh:message "A resource assessed by fairo:wasAssessedBy must point to a FAIR assessment." ;
    ] .

# Sub-Principle Result Shape

:SubPrincipleResultShape
    a sh:NodeShape ;
    sh:targetClass fairo:SubPrincipleResult ;

    sh:property [
        sh:path fairo:forSubPrinciple ;
        sh:class fairVocab:FAIR-SubPrinciple ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A sub-principle result must refer to exactly one FAIR sub-principle." ;
    ] ;

    sh:property [
        sh:path fairo:testResult ;
        sh:in (
            fairo:Pass
            fairo:Fail
            fairo:Indeterminate
        ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A sub-principle result must have exactly one test outcome: Pass, Fail, or Indeterminate." ;
    ] ;

    sh:property [
        sh:path fairo:assessmentScope ;
        sh:in (
            fairo:DataScope
            fairo:MetadataScope
            fairo:DataAndMetadata
        ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A sub-principle result must specify exactly one assessment scope." ;
    ] ;

    sh:property [
        sh:path fairo:value ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "A sub-principle result must have exactly one decimal value between 0 and 1." ;
    ] ;

    sh:property [
        sh:path fairo:evidence ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "A sub-principle result should include textual evidence." ;
    ] ;

    sh:property [
        sh:path fairo:computedUsing ;
        sh:class fairo:CalculationAlgorithm ;
        sh:maxCount 1 ;
        sh:message "If present, computedUsing must point to a CalculationAlgorithm." ;
    ] .


# Outcome / Score Consistency Rules

:PassResultShape
    a sh:NodeShape ;
    sh:targetClass fairo:SubPrincipleResult ;

    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "If testResult is Pass, the value must be exactly 1.0." ;
        sh:select """
            PREFIX fairo: <https://w3id.org/fair-o#>

            SELECT $this
            WHERE {
                $this fairo:testResult fairo:Pass ;
                      fairo:value ?value .
                FILTER (?value != 1.0)
            }
        """ ;
    ] .

:FailResultShape
    a sh:NodeShape ;
    sh:targetClass fairo:SubPrincipleResult ;

    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "If testResult is Fail, the value must be exactly 0.0." ;
        sh:select """
            PREFIX fairo: <https://w3id.org/fair-o#>

            SELECT $this
            WHERE {
                $this fairo:testResult fairo:Fail ;
                      fairo:value ?value .
                FILTER (?value != 0.0)
            }
        """ ;
    ] .

:IndeterminateResultShape
    a sh:NodeShape ;
    sh:targetClass fairo:SubPrincipleResult ;

    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "If testResult is Indeterminate, the value must be greater than 0 and less than 1." ;
        sh:select """
            PREFIX fairo: <https://w3id.org/fair-o#>

            SELECT $this
            WHERE {
                $this fairo:testResult fairo:Indeterminate ;
                      fairo:value ?value .
                FILTER (?value <= 0.0 || ?value >= 1.0)
            }
        """ ;
    ] .


# Assessment Scope Shape

:AssessmentScopeShape
    a sh:NodeShape ;
    sh:targetClass fairo:AssessmentScope ;

    sh:in (
        fairo:DataScope
        fairo:MetadataScope
        fairo:DataAndMetadata
    ) ;

    sh:message "Assessment scope must be one of DataScope, MetadataScope, or DataAndMetadata." .


# Test Outcome Shape

:TestOutcomeShape
    a sh:NodeShape ;
    sh:targetClass fairo:TestOutcome ;

    sh:in (
        fairo:Pass
        fairo:Fail
        fairo:Indeterminate
    ) ;

    sh:message "Test outcome must be one of Pass, Fail, or Indeterminate." .


# FAIR Sub-Principle Shape

:FAIRSubPrincipleShape
    a sh:NodeShape ;
    sh:targetClass fairVocab:FAIR-SubPrinciple ;

    sh:property [
        sh:path fairo:appliesTo ;
        sh:in (
            fairo:DataScope
            fairo:MetadataScope
            fairo:DataAndMetadata
        ) ;
        sh:maxCount 1 ;
        sh:message "A FAIR sub-principle may specify whether it applies to data, metadata, or both." ;
    ] .

# Scoring Function Shape

:ScoringFunctionShape
    a sh:NodeShape ;
    sh:targetClass fairo:ScoringFunction ;

    sh:property [
        sh:path fairo:minValue ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A scoring function must have exactly one minimum value." ;
    ] ;

    sh:property [
        sh:path fairo:maxValue ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message "A scoring function must have exactly one maximum value." ;
    ] ;

    sh:property [
        sh:path fairo:formula ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:message "A scoring function formula must be a string." ;
    ] ;

    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "The minimum value of a scoring function must not be greater than its maximum value." ;
        sh:select """
            PREFIX fairo: <https://w3id.org/fair-o#>

            SELECT $this
            WHERE {
                $this fairo:minValue ?min ;
                      fairo:maxValue ?max .
                FILTER (?min > ?max)
            }
        """ ;
    ] .

# Calculation Algorithm Shape

:CalculationAlgorithmShape
    a sh:NodeShape ;
    sh:targetClass fairo:CalculationAlgorithm ;

    sh:property [
        sh:path fairo:algorithmDescription ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:message "A calculation algorithm should have a human-readable description." ;
    ] ;

    sh:property [
        sh:path fairo:sourceCode ;
        sh:datatype xsd:anyURI ;
        sh:maxCount 1 ;
        sh:message "Source code must be provided as a URI." ;
    ] ;

    sh:property [
        sh:path fairo:appliesScoringFunction ;
        sh:class fairo:ScoringFunction ;
        sh:maxCount 1 ;
        sh:message "If present, appliesScoringFunction must point to a ScoringFunction." ;
    ] ;

    sh:property [
        sh:path fairo:implementedBy ;
        sh:class prov:SoftwareAgent ;
        sh:maxCount 1 ;
        sh:message "If present, implementedBy must point to a prov:SoftwareAgent." ;
    ] .

# Aggregation Method Shape

:AggregationMethodShape
    a sh:NodeShape ;
    sh:targetClass fairo:AggregationMethod ;

    sh:property [
        sh:path fairo:formula ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:message "An aggregation formula must be represented as a string." ;
    ] .

# Every SubPrincipleResult should be attached to at least one FAIRAssessment

:SubPrincipleResultAttachedToAssessmentShape
    a sh:NodeShape ;
    sh:targetClass fairo:SubPrincipleResult ;

    sh:property [
        sh:path [ sh:inversePath fairo:hasSubPrincipleResult ] ;
        sh:class fairo:FAIRAssessment ;
        sh:minCount 1 ;
        sh:message "Every sub-principle result should be linked from at least one FAIR assessment." ;
    ] .
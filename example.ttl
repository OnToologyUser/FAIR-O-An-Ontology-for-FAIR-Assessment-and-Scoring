@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix foaf: <http://www.foaf.org/spec/> .
@prefix exorg: <http://example.org/org#> .
@prefix fair: <http://example.org/fair-assessment#> .
@prefix : <http://example.org/data/> 

exdata:b3kat a dcat:Dataset, prov:Entity ;
    dct:title "B3Kat - Library Union Catalogues of Bavaria, Berlin and Brandenburg" ;
    dct:description "Joint Union Catalogue of 200 academic libraries in the german states of Bavaria, Berlin and Brandenburg. The data contains descriptions of 28Mio. titles and 69Mio. holdings available in these libraries. The available data dump in Turtle is approx. 9GB." ;
    dct:identifier "b3kat" ;
    dct:creator ex:researchInstitute .

exorg:researchInstitute a foaf:Organization ;
    foaf:name "Bavarian State Library, Bavarian Library Union, Cooperative Library Network Berlin-Brandenburg" ;
    foaf:mbox "lod@bsb-muenchen.de";

:kgheartbeat a prov:SoftwareAgent ;
    foaf:name "KGHeartbeat" ;
    dct:description "An Open Source Tool for Periodically Evaluating the Quality of Knowledge Graphs" .

:metadataScope a fair:AssessmentScope ;
    skos:prefLabel "Metadata Scope"@en ;
    skos:definition "The assessment is focused on the metadata of the digital object."@en .
    skos:notation "metadata" .

:dataScope a fair:AssessmentScope ;
    skos:prefLabel "Data Scope"@en ;
    skos:definition "The assessment is focused on the data of the digital object."@en .
    skos:notation "data" .

:metadataAndDataScope a fair:AssessmentScope ;
    skos:prefLabel "Metadata and Data Scope"@en ;
    skos:definition "The assessment is focused on both the metadata and the data of the digital object."@en .
    skos:notation "(meta)data" .

:F1M a fair:SubPrinciple ;
    skos:broader fair:Findable ;
    skos:prefLabel "Unique and persistent ID"@en ;
    skos:notation "F1-M" ;
    skos:definition "Assign a globally unique and persistent identifier to (meta)data."@en ;
    fair:appliesTo :metadataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:F1D a fair:SubPrinciple ;
    skos:broader fair:Findable ;
    skos:prefLabel "URIs dereferenceability"@en ;
    skos:notation "F1-D" ;
    skos:definition "Assign a globally unique and persistent identifier to (meta)data."@en ;
    fair:appliesTo :dataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:F2aM a fair:SubPrinciple ;
    skos:broader fair:Findable ;
    skos:prefLabel "Metadata availability via standard primary sources"@en ;
    skos:notation "F2a-M" ;
    skos:definition "Describe data using rich metadata"@en ;
    fair:appliesTo :metadataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:F2bM a fair:SubPrinciple ;
    skos:broader fair:Findable ;
    skos:prefLabel "Metadata availability for all the attributes covered in the FAIR score computation"@en ;
    skos:notation "F2b-M" ;
    skos:definition "Describe data using rich metadata"@en ;
    fair:appliesTo :metadataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:F3M a fair:SubPrinciple ;
    skos:broader fair:Findable ;
    skos:prefLabel "Data referrable via a DOI"@en ;
    skos:notation "F3-M" ;
    skos:definition "Metadata must include the identifier of the described data."@en ;
    fair:appliesTo :metadataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:F4M a fair:SubPrinciple ;
    skos:broader fair:Findable ;
    skos:prefLabel "Metadata registered in a searchable engine"@en ;
    skos:notation "F4-M" ;
    skos:definition "Ensure (meta)data are indexed in searchable repositories."@en ;
    fair:appliesTo :metadataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:A11D a fair:SubPrinciple ;
    skos:broader fair:Accessible ;
    skos:prefLabel "Working access point(s)"@en ;
    skos:notation "A1.1-D" ;
    skos:definition "The protocol should be open, freely implementable, and universally usable."@en ;
    fair:appliesTo :dataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:A11M a fair:SubPrinciple ;
    skos:broader fair:Accessible ;
    skos:prefLabel "Metadata availability via working primary sources"@en ;
    skos:notation "A1.1-M" ;
    skos:definition "The protocol should be open, freely implementable, and universally usable."@en ;
    fair:appliesTo :metadataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:A12 a fair:SubPrinciple ;
    skos:broader fair:Accessible ;
    skos:prefLabel "Authentication & HTTPS support"@en ;
    skos:notation "A1.2" ;
    skos:definition "It should support authentication and authorization if needed."@en ;
    fair:appliesTo :metadataAndDataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:A2M a fair:SubPrinciple ;
    skos:broader fair:Accessible ;
    skos:prefLabel "Registered in search engines"@en ;
    skos:notation "A2-M" ;
    skos:definition "Metadata should remain available even when the data are no longer hosted."@en ;
    fair:appliesTo :metadataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:I1D a fair:SubPrinciple ;
    skos:broader fair:Interoperable ;
    skos:prefLabel "Standard & open representation format"@en ;
    skos:notation "I1-D" ;
    skos:definition "Represent knowledge using formal, shared, and accessible languages"@en ;
    fair:appliesTo :dataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:I1M a fair:SubPrinciple ;
    skos:broader fair:Interoperable ;
    skos:prefLabel "Metadata are described with VoID/DCAT predicates"@en ;
    skos:notation "I1-M" ;
    skos:definition "Represent knowledge using formal, shared, and accessible languages."@en ;
    fair:appliesTo :metadataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:I2 a fair:SubPrinciple ;
    skos:broader fair:Interoperable ;
    skos:prefLabel "Use of FAIR vocabularies"@en ;
    skos:notation "I2" ;
    skos:definition "Rely on vocabularies that conform to FAIR standards."@en
    fair:appliesTo :metadataAndDataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:I3D a fair:SubPrinciple ;
    skos:broader fair:Interoperable ;
    skos:prefLabel "Degree of connection"@en ;
    skos:notation "I3-D" ;
    skos:definition "Include qualified references to other (meta)data."@en ;
    fair:appliesTo :dataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:R11 a fair:SubPrinciple ;
    skos:broader fair:Reusable ;
    skos:prefLabel "Any license retrievable via any primary source"@en ;
    skos:notation "R1.1" ;
    skos:definition "Attach a clear and accessible usage license."@en ;
    fair:appliesTo :metadataAndDataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:R12 a fair:SubPrinciple ;
    skos:broader fair:Reusable ;
    skos:prefLabel "Publisher details (sources, authors, contributors)"@en ;
    skos:notation "R1.2" ;
    skos:definition "Record provenance information."@en ;
    fair:appliesTo :metadataAndDataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:R13D a fair:SubPrinciple ;
    skos:broader fair:Reusable ;
    skos:prefLabel "Data organized in standardized ways"@en ;
    skos:notation "R1.3-D" ;
    skos:definition "Conform to domain-relevant community standards."@en ;
    fair:appliesTo :dataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:R13M a fair:SubPrinciple ;
    skos:broader fair:Reusable ;
    skos:prefLabel "Metadata are described with VoID/DCAT predicates"@en ;
    skos:notation "R1.3-M" ;
    skos:definition "Conform to domain-relevant community standards."@en ;
    fair:appliesTo :metadataScope ;
    dct:source <https://doi.org/10.1145/3746252.3761092> .

:Pass a fair:TestOutcome ;
    skos:prefLabel "Pass"@en ;
    skos:definition "The resource meets the subprinciple criteria."@en .

:Fail a fair:TestOutcome ;
    skos:prefLabel "Fail"@en ;
    skos:definition "The resource does not meet the subprinciple criteria."@en .

:PartialPass a fair:TestOutcome ;
    skos:prefLabel "Partial Pass"@en ;
    skos:definition "The resource partially meets the subprinciple criteria."@en .

:Indeterminate a fair:TestOutcome ;
    skos:prefLabel "Indeterminate"@en ;
    skos:definition "It is not possible to determine if the resource meets the subprinciple criteria, due to insufficient or ambiguous information."@en .

:algF1M a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "Checks whether the Knowledge Graph, identified by its KG identifier, is indexed in the Linked Open Data Cloud, DataHub or CHeCLOUD search engines.
        In parallel, it verifies the presence of a Digital Object Identifier (DOI) associated with the same Knowledge Graph.
        If at least one of these two conditions holds—namely, the Knowledge Graph is discoverable via the search engine or it is associated with a DOI."@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/evaluate_fairness.py#L15-L19> .
    fair:appliesScoringFunction :binaryScoringFunction .

:algF1D a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "checks URI dereferencability by first attempting to retrieve 5000 random URIs from a SPARQL endpoint, validates each URI, and tries to fetch it with an HTTP GET request accepting RDF/XML with a 2-second timeout, counting successful responses with status code 200."@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/analyses.py#L1385C1-L1433C17> .
    fair:appliesScoringFunction :derefRatio .

:algF2aM a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "checks whether at least one access mechanism is provided for the knowledge graph. It assigns a value of 1 to the SPARQL indication if a SPARQL endpoint URL is present, and a value of 1 to the VoID indication if a VoID URL is present; otherwise, both are set to 0."@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/evaluate_fairness.py#L27-L29> .
    fair:appliesScoringFunction :binaryScoringFunction .

:algF2bM a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "the arithmetic mean of nine binary indicators—SPARQL availability, DOI presence, data dump availability, verifiability information (checking if at least an author from metadata or query, the contributors, the publishers or source are available), media type specification, license declaration, vocabulary usage, presence of links, and VoID availability—and rounds the resulting value to two decimal places."@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/evaluate_fairness.py#L45> .
    fair:appliesScoringFunction :ratioScoringFunction .

:algF3M a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "retrieves metadata for a given knowledge graph identifier and attempts to obtain a DOI from three different sources: the LOD Cloud, Monitoring Resources, and CHeCloud. It first extracts the DOI from the LOD Cloud metadata, then queries Monitoring Resources and CHeCloud independently, logging the retrieved values. The algorithm returns the first DOI that is neither false nor null, following the priority order of LOD Cloud, Monitoring Resources, and CHeCloud; if no valid DOI is found from any source, it returns false."@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/API/Aggregator.py#L202-L216> .
    fair:appliesScoringFunction :binaryScoringFunction .

:algF4M a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "verifies if the knowledge graph is indexed in at least one of the two search engines: LOD Cloud or DataHub."@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/API/Aggregator.py#L24-L32> ;
    fair:appliesScoringFunction :binaryScoringFunction . 

:algA11D a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "evaluates the accessibility of the knowledge graph by checking the availability of a SPARQL endpoint and an RDF dump. If the SPARQL endpoint or a RDF dump is available and operative, a value of 1 is assigned. If one of it is only indicated but not operative, 0.5 is assigned. 0 if is either sparql endpoint and rdf dump are not indicated."@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/evaluate_fairness.py#L56-L61>.

:algA11M a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "It first checks whether the knowledge graph is listed on either of two search engines: DataHub or LOD Cloud. If the knowledge graph is found on either platform (indicated by receiving valid dictionary metadata from their APIs), the accessibility score is set to 1. If not found on these search engines, the algorithm falls back to checking two alternative availability indicators: whether a SPARQL endpoint is available, or whether a VoID (Vocabulary of Interlinked Datasets) file is available. The accessibility score is set to 1 if at least one of these alternatives is available, otherwise it remains 0."@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/evaluate_fairness.py#L63-L69> ;
    fair:appliesScoringFunction :binaryScoringFunction .

:algA12 a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "calculates an accessibility sub-metric (a1_2) based on two security-related factors. First, it checks whether the dataset uses HTTPS or has an available SPARQL endpoint, assigning a score of 1 if either condition is true. Second, it checks the authentication requirement status, assigning a score of 1 if it can be detected as authntication needed or not needed."@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/evaluate_fairness.py#L71C1-L74C75> ;
    fair:appliesScoringFunction :binaryScoringFunction .

:algA2M a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "Checks if the dataset is available on DataHub or LOD Cloud search engines. Additionally, also check if it is on github, zenodo or faircharing "@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/evaluate_fairness.py#L76> ;
    fair:appliesScoringFunction :binaryScoringFunction .

:algI1D a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "It first checks whether the knowledge graph is listed on DataHub or LOD Cloud search engines. Then it evaluates two conditions: whether the knowledge graph uses a common media type, and whether its metadata media type includes a known semantic format (specifically SPARQL API, or RDF in any case). The interoperability score is set to 1 if either the common media type flag is true or a recognized semantic format is found in the metadata, otherwise it is set to 0."@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/evaluate_fairness.py#L105C1-L109C83> ;
    fair:appliesScoringFunction :binaryScoringFunction .

:algI1M a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "It checks two sources for VoID (Vocabulary of Interlinked Datasets) availability: whether a VoID URL exists in the metadata, and whether a VoID or DCAT description can be retrieved by querying the SPARQL endpoint directly. The final interoperability score is set to 1 if a VoID description is available from either source, otherwise it is set to 0."@en ;
    fair:appliesScoringFunction :binaryScoringFunction .
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/evaluate_fairness.py#L111-L114> .

:algI2 a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "It first checks whether the dataset has any vocabularies defined by verifying the vocabularies field in the metadata is not empty. If vocabularies are present, it evaluates whether those vocabularies comply with FAIR (Findable, Accessible, Interoperable, Reusable) principles (checking if it is registered in FAIRSharing catalogue) and assigns the result as the metric value. If no vocabularies are defined, the metric is set to 0."@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/evaluate_fairness.py#L116C1-L117C118> ;
    fair:appliesScoringFunction :ratioScoringFunction .

:algI3D a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "f the knowledge graph is available on a search engine, it checks whether the degree of connection to other datasets is greater than zero, setting the metric to 1 if true and 0 otherwise, with error handling for type conversion issues. If the knowledge graph is not on a search engine, it alternatively checks for the presence of interlinking through two methods: owl:sameAs links or SKOS mapping relations. The metric is set to 1 if either of these interlinking indicators has a value greater than zero, otherwise it is set to 0."@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/evaluate_fairness.py#L119-L127> ;
    fair:appliesScoringFunction :binaryScoringFunction .

:algR11 a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "It evaluates three possible sources of licensing information: whether license metadata is present and valid, whether a license can be retrieved through a query, and whether a human-readable license is available and confirmed. The final reusability score is set to 1 if licensing information is available from at least one of these three sources, otherwise it is set to 0."@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/evaluate_fairness.py#L84-L87> ;
    fair:appliesScoringFunction :binaryScoringFunction .

:algR12 a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "It evaluates five possible sources of provenance data: author information obtained through a query, author information from metadata (excluding entries where both name and email are marked as absent), contributor information, publisher information, and source attribution (checking if at least one of name, web address, or email is present). The final score is set to 1 if any of these five provenance indicators contains valid information, otherwise it is set to 0."@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/evaluate_fairness.py#L89> ;
    fair:appliesScoringFunction :binaryScoringFunction .

:algR13D a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "It checks two conditions: whether the knowledge graph uses a common media type, and whether the metadata media type includes a recognized semantic format (specifically SPARQL API or RDF). The final score is set to 1 if either the common media type flag is true or a known semantic format is detected, otherwise it is set to 0."@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/evaluate_fairness.py#L91-L93> ;
    fair:appliesScoringFunction :binaryScoringFunction .

:algR13M a fair:CalculationAlgorithm ;
    fair:implementedBy :kgheartbeat ;
    fair:algorithmDescription "It checks two sources for VoID (Vocabulary of Interlinked Datasets) availability: whether a VoID URL exists in the metadata, and whether a VoID or DCAT description can be retrieved by querying the SPARQL endpoint directly. The final interoperability score is set to 1 if a VoID description is available from either source, otherwise it is set to 0."@en ;
    fair:sourceCode <https://github.com/isislab-unisa/KGHeartBeat/blob/ffa6aa9fa6101487daec3f90d0d1894c1750aacb/src/evaluate_fairness.py#L95C1-L98C92> ;
    fair:appliesScoringFunction :binaryScoringFunction .

:ratioScoringFunction a fair:ScoringFunction ;
    fair:formula "Number of successful conditions / Total number of conditions"^^xsd:string ;
    fair:minValue "0"^^xsd:decimal ;
    fair:maxValue "1"^^xsd:decimal ;
    dct:description "A scoring function that calculates the ratio of successful conditions to the total number of conditions."@en ;
    skos:prefLabel "Ratio Scoring Function"@en .

:binaryScoringFunction a fair:ScoringFunction ;
    fair:formula "IF condition = 'Satisfied' THEN 1 ELSE 0"^^xsd:string ;
    fair:minValue "0"^^xsd:decimal ;
    fair:maxValue "1"^^xsd:decimal ;
    dct:description "A scoring function that assigns a score of 1 if the condition is satisfied and 0 otherwise."@en ;
    skos:prefLabel "Binary Scoring Function"@en .

:linearCombination a fair:AggregationMethod ;
    fair:formula "Score(P) = (1/n) * sum_{i=1..n}(s_i), where s_i in [0,1] and Score(P) in [0,1].
        FAIR_Score = sum_{j=1..4}(Score(P_j)), where FAIR_Score in [0,4]."^^xsd:string ;
    dct:description "The score of a principle is computed as the arithmetic mean of the scores of its associated sub-principles. Specifically, each sub-principle contributes a value in the range  [0,1] and the principle score is obtained by summing all sub-principle scores and dividing by the total number of sub-principles, resulting in a normalized value between 0 and 1. The overall FAIR score is then calculated by aggregating the scores of the four FAIR principles. This aggregation is performed as a simple sum of the individual principle scores, producing a final FAIR score that ranges from 0 to 4."@en .
    skos:prefLabel "Linear Combination"@en ;

:derefRatio a fair:ScoringFunction ;
    fair:formula "Number of dereferenceable URIs / Total number of URIs"^^xsd:string ;
    fair:minValue "0"^^xsd:decimal ;
    fair:maxValue "1"^^xsd:decimal ;
    dct:description "The dereferencability value is calculated as the ratio of successfully dereferenced URIs to the total count of valid URIs. ."@en .
    skos:prefLabel "Dereferenceability Ratio"@en ;
    .

